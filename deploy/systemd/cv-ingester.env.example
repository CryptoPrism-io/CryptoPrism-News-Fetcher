# cv-ingester.env.example  ->  install as /etc/cv-ingester.env
# DB_* come from the GitHub Actions secrets (source of truth), NOT local .env.
# If the VM is in the same AWS VPC as the DB, use the DB's private IP for DB_HOST
# (172.31.82.167 as of 2026-07-21) so traffic stays internal.
CCV_BASE_URL=http://127.0.0.1:3000
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=dbcp
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
